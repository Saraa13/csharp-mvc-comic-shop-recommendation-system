@model List<dynamic>

@{
    ViewData["Title"] = "Recommended Mangas";
}

<div class="bg-light">
    <div class="container py-4">
        <h2 class="pb-4 text-center">Recommended Mangas</h2>

        @if (Model.Any())
        {
            <div class="row mb-5 g-3">
                @foreach (var recommendation in Model)
                {
                    <div class="col-lg-3 col-md-6">
                        <div class="rounded border shadow p-3 text-center h-100">
                            <img src="/products/@recommendation.Product.ImageFileName" class="img-fluid" alt="..."
                                 style="height: 250px; object-fit:contain" />
                            <hr />
                            <h5 class="py-2">@recommendation.Product.Name</h5>
                            <p>
                                Publisher: @recommendation.Product.Publisher, Genre: @recommendation.Product.Genre
                            </p>
                            <h4 class="mb-3">@(recommendation.Product.Price)$</h4>

                            <a class="btn btn-primary btn-sm mb-2" asp-controller="Store"
                               asp-action="Details" asp-route-id="@recommendation.Product.Id" role="button">Details</a>
                            <button type="button" class="btn btn-warning btn-sm mb-2" onclick="addToCart(this, @recommendation.Product.Id)">
                                Add to Cart <i class="bi bi-cart4"></i>
                            </button>

                            <div class="mt-3">
                                <small class="text-muted">Recommendation: @recommendation.RecommendationType</small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-center text-danger">No recommendations available at the moment.</p>
        }
    </div>
</div>

